m i better-sqlite3\\n *\\n * ENV: STITCH_DB_FILE=stitchbrick.db  STITCH_TELEMETRY=1  STITCH_THROTTLE=1\\n * CLI:\\n *   node stitchbrick.js --verify --state IL\\n *   node stitchbrick.js --snapshot --state IL\\n *   node stitchbrick.js --restore --state IL\\n *   node stitchbrick.js --condense --state IL\\n *   node stitchbrick.js --restore-snap \u003cSNAP_HASH\u003e\\n *   node stitchbrick.js --stress 15 --state IL\\n */\\n\\n\\\"use strict\\\";\\n\\nconst os = require(\\\"os\\\");\\nconst crypto = require(\\\"crypto\\\");\\nconst zlib = require(\\\"zlib\\\");\\nconst Database = require(\\\"better-sqlite3\\\");\\n\\nconst ERR = Object.freeze({\\n  INVALID_STATE_TAG: \\\"INVALID_STATE_TAG\\\",\\n  INVALID_STREAM: \\\"INVALID_STREAM\\\",\\n  INVALID_TYPE: \\\"INVALID_TYPE\\\",\\n  INVALID_ACTOR: \\\"INVALID_ACTOR\\\",\\n  NONFINITE_NUMBER: \\\"NONFINITE_NUMBER\\\",\\n  PREV_HASH_MISMATCH: \\\"PREV_HASH_MISMATCH\\\",\\n  HASH_CORRUPTION: \\\"HASH_CORRUPTION\\\",\\n  NO_SNAPSHOT: \\\"NO_SNAPSHOT\\\",\\n  SNAPSHOT_TAMPERED: \\\"SNAPSHOT_TAMPERED\\\",\\n  SNAPSHOT_INVALID: \\\"SNAPSHOT_INVALID\\\",\\n  POST_RESTORE_VERIFY_FAILED: \\\"POST_RESTORE_VERIFY_FAILED\\\",\\n  STRESS_FAILED: \\\"STRESS_FAILED\\\",\\n});\\n\\nconst DB_FILE = process.env.STITCH_DB_FILE || \\\"stitchbrick.db\\\";\\nconst GENESIS = \\\"0\\\".repeat(64);\\nconst TELEMETRY_ON = process.env.STITCH_TELEMETRY === \\\"1\\\";\\nconst THROTTLE_ON = process.env.STITCH_THROTTLE === \\\"1\\\";\\n\\nconst db = new Database(DB_FILE);\\ndb.exec(`\\nPRAGMA journal_mode=WAL; PRAGMA synchronous=FULL; PRAGMA foreign_keys=ON;\\n\\nCREATE TABLE IF NOT EXISTS stitch_meta(k TEXT PRIMARY KEY, v TEXT NOT NULL);\\nINSERT OR IGNORE INTO stitch_meta(k,v) VALUES ('GENESIS_PREV_HASH','${GENESIS}');\\n\\nCREATE TABLE IF NOT EXISTS ledger_events(\\n  id INTEGER PRIMARY KEY AUTOINCREMENT,\\n  event_id TEXT NOT NULL UNIQUE,\\n  ts INTEGER NOT NULL,\\n  state_tag TEXT NOT NULL,\\n  stream TEXT NOT NULL,\\n  type TEXT NOT NULL,\\n  actor TEXT NOT NULL,\\n  request_id TEXT,\\n  prev_hash TEXT NOT NULL,\\n  event_hash TEXT NOT NULL UNIQUE,\\n  payload_json TEXT NOT NULL\\n);\\nCREATE INDEX IF NOT EXISTS idx_ledger_state_id ON ledger_events(state_tag,id);\\nCREATE INDEX IF NOT EXISTS idx_ledger_state_ts ON ledger_events(state_tag,ts);\\n\\nCREATE TABLE IF NOT EXISTS snapshots(\\n  id INTEGER PRIMARY KEY AUTOINCREMENT,\\n  state_tag TEXT NOT NULL,\\n  snapshot_hash TEXT NOT NULL UNIQUE,\\n  head_event_id INTEGER NOT NULL DEFAULT 0,\\n  head_event_hash TEXT NOT NULL DEFAULT '${GENESIS}',\\n  blob BLOB NOT NULL,\\n  ts INTEGER NOT NULL\\n);\\nCREATE INDEX IF NOT EXISTS idx_snap_state_ts ON snapshots(state_tag,ts);\\n`);\\n\\nconst fail = (code, extra = {}) =\u003e { const e = new Error(code); e.code = code; e.extra = extra; throw e; };\\nconst assert = (c, code, extra = {}) =\u003e { if (!c) fail(code, extra); };\\n\\nconst canon = (v) =\u003e {\\n  if (v === null) return \\\"null\\\";\\n  const t = typeof v;\\n  if (t === \\\"number\\\") { if (!Number.isFinite(v)) fail(ERR.NONFINITE_NUMBER); if (Object.is(v, -0)) return \\\"0\\\"; return String(v); }\\n  if (t === \\\"boolean\\\") return v ? \\\"true\\\" : \\\"false\\\";\\n  if (t === \\\"string\\\") return JSON.stringify(v);\\n  if (t === \\\"bigint\\\") return JSON.stringify(v.toString());\\n  if (t === \\\"undefined\\\") return \\\"null\\\";\\n  if (Array.isArray(v)) return \\\"[\\\" + v.map(canon).join(\\\",\\\") + \\\"]\\\";\\n  if (t === \\\"object\\\") {\\n    const keys = Object.keys(v).sort();\\n    return \\\"{\\\" + keys.filter(k =\u003e typeof v[k] !== \\\"undefined\\\").map(k =\u003e JSON.stringify(k) + \\\":\\\" + canon(v[k])).join(\\\",\\\") + \\\"}\\\";\\n  }\\n  fail(\\\"UNSUPPORTED_TYPE\\\", { type: t });\\n};\\n\\nconst sha = (d) =\u003e crypto.createHash(\\\"sha256\\\").update(d).digest(\\\"hex\\\");\\nconst shaBuf = (b) =\u003e crypto.createHash(\\\"sha256\\\").update(b).digest(\\\"hex\\\");\\nconst uuid = () =\u003e crypto.randomUUID();\\n\\nconst normTag = (s) =\u003e {\\n  const tag = String(s || \\\"\\\").toUpperCase();\\n  assert(/^[A-Z0-9_]{2,16}$/.test(tag), ERR.INVALID_STATE_TAG, { tag });\\n  return tag;\\n};\\nconst okStream = (s) =\u003e typeof s === \\\"string\\\" \u0026\u0026 /^[a-z0-9_]{2,48}$/.test(s);\\nconst okType = (s) =\u003e typeof s === \\\"string\\\" \u0026\u0026 /^[A-Z0-9_]{3,64}$/.test(s);\\nconst okActor = (s) =\u003e typeof s === \\\"string\\\" \u0026\u0026 /^[A-Z0-9_]{2,32}$/.test(s);\\n\\nconst genesis = () =\u003e db.prepare(`SELECT v FROM stitch_meta WHERE k='GENESIS_PREV_HASH'`).get()?.v || GENESIS;\\n\\nconst vitals = () =\u003e {\\n  const c = os.cpus().length || 1;\\n  const l = os.loadavg()[0] || 0;\\n  const free = os.freemem(), total = os.totalmem();\\n  const m = total ? free / total : 0;\\n  const s = l / c;\\n  return {\\n    cpu_load_1m: +l.toFixed(4),\\n    cpu_cores: c,\\n    cpu_stress_ratio: +s.toFixed(4),\\n    memory_free_ratio: +m.toFixed(4),\\n    uptime_seconds: Math.floor(os.uptime()),\\n    ts: Date.now(),\\n    system_stressed: (s \u003e 0.9 || m \u003c 0.1),\\n  };\\n};\\nconst throttle = (v) =\u003e {\\n  if (!THROTTLE_ON || !v.system_stressed) return;\\n  const ms = Math.min(250, Math.max(10, Math.floor(v.cpu_stress_ratio * 120)));\\n  const st = Date.now(); while (Date.now() - st \u003c ms) {}\\n};\\n\\nconst head = (tag) =\u003e {\\n  const r = db.prepare(`SELECT id,event_hash FROM ledger_events WHERE state_tag=? ORDER BY id DESC LIMIT 1`).get(tag);\\n  return r ? { id: r.id, hash: r.event_hash } : { id: 0, hash: genesis() };\\n};\\n\\nconst eventHash = (h) =\u003e sha(\\n  canon({\\n    prev_hash: h.prev_hash,\\n    ts: h.ts,\\n    state_tag: h.state_tag,\\n    stream: h.stream,\\n    type: h.type,\\n    actor: h.actor,\\n    request_id: h.request_id || null,\\n    event_id: h.event_id\\n  }) + \\\"\\\\n\\\" + h.payload_json\\n);\\n\\n// ==============================\\n// STITCHBRICK CORE: append/verify\\n// ==============================\\nfunction stitchBrick(input) {\\n  const state_tag = normTag(input.state_tag);\\n  const stream = input.stream;\\n  const type = input.type;\\n  const actor = String(input.actor || \\\"SYSTEM\\\").toUpperCase();\\n  const request_id = input.request_id || null;\\n  const event_id = input.event_id || uuid();\\n  const ts = Number.isInteger(input.ts) ? input.ts : Date.now();\\n\\n  assert(okStream(stream), ERR.INVALID_STREAM, { stream });\\n  assert(okType(type), ERR.INVALID_TYPE, { type });\\n  assert(okActor(actor), ERR.INVALID_ACTOR, { actor });\\n\\n  const v = TELEMETRY_ON ? vitals() : null;\\n  if (v) throttle(v);\\n\\n  const prev = head(state_tag).hash;\\n  const payload = input.payload || {};\\n  const payload_json = canon(v ? {\\n    ...payload,\\n    _vitals: { cpu_load_1m: v.cpu_load_1m, cpu_stress_ratio: v.cpu_stress_ratio, memory_free_ratio: v.memory_free_ratio, uptime_seconds: v.uptime_seconds, ts: v.ts }\\n  } : payload);\\n\\n  const event_hash = eventHash({ prev_hash: prev, ts, state_tag, stream, type, actor, request_id, event_id, payload_json });\\n\\n  const info = db.prepare(\\n    `INSERT OR IGNORE INTO ledger_events(event_id,ts,state_tag,stream,type,actor,request_id,prev_hash,event_hash,payload_json)\\n     VALUES (?,?,?,?,?,?,?,?,?,?)`\\n  ).run(event_id, ts, state_tag, stream, type, actor, request_id, prev, event_hash, payload_json);\\n\\n  if (info.changes === 0) {\\n    const row = db.prepare(`SELECT id,event_id,event_hash,prev_hash,ts FROM ledger_events WHERE event_id=?`).get(event_id);\\n    return { ok: true, idempotent: true, ...row };\\n  }\\n  return { ok: true, idempotent: false, id: info.lastInsertRowid, event_id, event_hash, prev_hash: prev, ts };\\n}\\n\\nfunction list(tag) {\\n  tag = normTag(tag);\\n  return db.prepare(\\n    `SELECT id,event_id,ts,state_tag,stream,type,actor,request_id,prev_hash,event_hash,payload_json\\n     FROM ledger_events WHERE state_tag=? ORDER BY id ASC`\\n  ).all(tag);\\n}\\n\\nfunction verify(tag) {\\n  tag = normTag(tag);\\n  const rows = list(tag);\\n  let prev = genesis();\\n  for (const r of rows) {\\n    if (r.prev_hash !== prev) return { ok: false, error: ERR.PREV_HASH_MISMATCH, at_id: r.id, expectedPrev: prev, foundPrev: r.prev_hash };\\n    const computed = eventHash({\\n      prev_hash: r.prev_hash, ts: r.ts, state_tag: r.state_tag, stream: r.stream, type: r.type,\\n      actor: r.actor, request_id: r.request_id, event_id: r.event_id, payload_json: r.payload_json\\n    });\\n    if (computed !== r.event_hash) return { ok: false, error: ERR.HASH_CORRUPTION, at_id: r.id, computed, recorded: r.event_hash };\\n    prev = r.event_hash;\\n  }\\n  return { ok: true, count: rows.length, head_hash: prev };\\n}\\n\\n// ==============================\\n// SNAPSHOT ENGINE (existing)\\n// ==============================\\nfunction snapshot(tag) {\\n  tag = normTag(tag);\\n  const events = list(tag);\\n  const h = head(tag);\\n  const payload = { v: 1, state_tag: tag, created_ts: Date.now(), head_event_id: h.id, head_event_hash: h.hash, events };\\n  const json = canon(payload);\\n  const blob = zlib.gzipSync(Buffer.from(json, \\\"utf8\\\"));\\n  const snapshot_hash = shaBuf(blob);\\n\\n  db.prepare(`INSERT INTO snapshots(state_tag,snapshot_hash,head_event_id,head_event_hash,blob,ts) VALUES (?,?,?,?,?,?)`)\\n    .run(tag, snapshot_hash, h.id, h.hash, blob, Date.now());\\n\\n  return { ok: true, snapshot_hash, bytes: blob.length, events: events.length, head_event_id: h.id, head_event_hash: h.hash };\\n}\\n\\nfunction latestSnap(tag) {\\n  tag = normTag(tag);\\n  return db.prepare(`SELECT id,state_tag,snapshot_hash,head_event_id,head_event_hash,blob,ts FROM snapshots WHERE state_tag=? ORDER BY ts DESC LIMIT 1`).get(tag) || null;\\n}\\n\\n// ==============================\\n// COMPRESSION ENGINE (v1.5.1) ADDED\\n// (Uses same snapshots table; stores FULL ledger as canonical payload)\\n// ==============================\\nfunction condenseDistrictState(tag) {\\n  tag = normTag(tag);\\n\\n  const events = db.prepare(\\n    `SELECT id,event_id,ts,state_tag,stream,type,actor,request_id,prev_hash,event_hash,payload_json\\n     FROM ledger_events WHERE state_tag=? ORDER BY id ASC`\\n  ).all(tag);\\n\\n  const payload = { v: 2, kind: \\\"FULL\\\", state_tag: tag, created_ts: Date.now(), events };\\n  const canonicalJson = canon(payload);\\n\\n  const blob = zlib.gzipSync(Buffer.from(canonicalJson, \\\"utf8\\\"));\\n  const snapshot_hash = shaBuf(blob);\\n\\n  // For compatibility, write head pointers too\\n  const h = head(tag);\\n\\n  db.prepare(\\n    `INSERT INTO snapshots(state_tag,snapshot_hash,head_event_id,head_event_hash,blob,ts)\\n     VALUES (?,?,?,?,?,?)`\\n  ).run(tag, snapshot_hash, h.id, h.hash, blob, Date.now());\\n\\n  const rawBytes = Buffer.byteLength(canonicalJson, \\\"utf8\\\");\\n  const reduction_pct = rawBytes ? +((1 - blob.length / rawBytes) * 100).toFixed(2) : 0;\\n\\n  return { ok: true, snapshot_hash, bytes: blob.length, reduction_pct, events: events.length, head_event_id: h.id, head_event_hash: h.hash };\\n}\\n\\nfunction restoreDistrictStateByHash(snapshot_hash) {\\n  const snap = db.prepare(`SELECT state_tag,snapshot_hash,blob FROM snapshots WHERE snapshot_hash=?`).get(snapshot_hash);\\n  if (!snap) fail(ERR.NO_SNAPSHOT, { snapshot_hash });\\n\\n  if (shaBuf(snap.blob) !== snap.snapshot_hash) fail(ERR.SNAPSHOT_TAMPERED, { snapshot_hash: snap.snapshot_hash });\\n\\n  const json = zlib.gunzipSync(snap.blob).toString(\\\"utf8\\\");\\n  const payload = JSON.parse(json);\\n\\n  // Accept both v1 and v2 payloads\\n  const okV1 = payload \u0026\u0026 payload.v === 1 \u0026\u0026 payload.state_tag === snap.state_tag \u0026\u0026 Array.isArray(payload.events);\\n  const okV2 = payload \u0026\u0026 payload.v === 2 \u0026\u0026 payload.kind === \\\"FULL\\\" \u0026\u0026 payload.state_tag === snap.state_tag \u0026\u0026 Array.isArray(payload.events);\\n  if (!okV1 \u0026\u0026 !okV2) fail(ERR.SNAPSHOT_INVALID, { snapshot_hash });\\n\\n  const tag = snap.state_tag;\\n  const rows = payload.events;\\n\\n  db.exec(`DROP TABLE IF EXISTS ledger_recovery;`);\\n  db.exec(`CREATE TABLE ledger_recovery AS SELECT * FROM ledger_events WHERE 1=0;`);\\n\\n  const ins = db.prepare(`\\n    INSERT INTO ledger_recovery(id,event_id,ts,state_tag,stream,type,actor,request_id,prev_hash,event_hash,payload_json)\\n    VALUES (?,?,?,?,?,?,?,?,?,?,?)\\n  `);\\n\\n  db.transaction((data) =\u003e {\\n    for (const r of data) {\\n      if (r.state_tag !== tag) continue; // BRICS isolation\\n      ins.run(\\n        r.id ?? null,\\n        r.event_id,\\n        r.ts,\\n        r.state_tag,\\n        r.stream,\\n        r.type,\\n        r.actor ?? \\\"SYSTEM\\\",\\n        r.request_id ?? null,\\n        r.prev_hash,\\n        r.event_hash,\\n        r.payload_json\\n      );\\n    }\\n  })(rows);\\n\\n  db.exec(`\\n    BEGIN IMMEDIATE TRANSACTION;\\n    DELETE FROM ledger_events WHERE state_tag='${tag}';\\n    INSERT INTO ledger_events(event_id,ts,state_tag,stream,type,actor,request_id,prev_hash,event_hash,payload_json)\\n      SELECT event_id,ts,state_tag,stream,type,actor,request_id,prev_hash,event_hash,payload_json\\n      FROM ledger_recovery WHERE state_tag='${tag}';\\n    DROP TABLE ledger_recovery;\\n    COMMIT;\\n  `);\\n\\n  const v = verify(tag);\\n  if (!v.ok) fail(ERR.POST_RESTORE_VERIFY_FAILED, v);\\n\\n  return { ok: true, state_tag: tag, restored_events: rows.length, head_hash: v.head_hash };\\n}\\n\\n// Keep old name for compatibility\\nfunction shadowHeal(tag) {\\n  tag = normTag(tag);\\n  const snap = latestSnap(tag);\\n  if (!snap) fail(ERR.NO_SNAPSHOT, { tag });\\n  return restoreDistrictStateByHash(snap.snapshot_hash);\\n}\\n\\n// ==============================\\n// CHAOS + STRESS\\n// ==============================\\nfunction chaos(tag) {\\n  tag = normTag(tag);\\n\\n  stitchBrick({ state_tag: tag, stream: \\\"domain\\\", type: \\\"ENTITY_CREATED\\\", actor: \\\"SYSTEM\\\", request_id: uuid(), payload: { entity_id: \\\"ent_1\\\", kind: \\\"org\\\", name: \\\"ACME\\\" } });\\n  stitchBrick({ state_tag: tag, stream: \\\"domain\\\", type: \\\"CASE_CREATED\\\", actor: \\\"SYSTEM\\\", request_id: uuid(), payload: { case_id: \\\"case_1\\\", entity_id: \\\"ent_1\\\", title: \\\"Service Request\\\", status: \\\"open\\\" } });\\n\\n  for (let i = 0; i \u003c 100; i++) {\\n    stitchBrick({ state_tag: tag, stream: \\\"chaos\\\", type: \\\"ENTROPY_INJECTION\\\", actor: \\\"SYSTEM\\\", request_id: `chaos-${i}`, payload: { i, entropy: crypto.randomBytes(8).toString(\\\"hex\\\") } });\\n  }\\n\\n  let v = verify(tag); assert(v.ok, \\\"BASELINE_VERIFY_FAILED\\\");\\n  const s = snapshot(tag);\\n\\n  const target = db.prepare(`SELECT id FROM ledger_events WHERE state_tag=? ORDER BY id ASC LIMIT 1 OFFSET 50`).get(tag);\\n  if (target?.id) db.prepare(`UPDATE ledger_events SET payload_json='{\\\"corrupted\\\":true}' WHERE id=?`).run(target.id);\\n\\n  v = verify(tag); assert(!v.ok, \\\"TAMPER_NOT_DETECTED\\\");\\n\\n  const healed = shadowHeal(tag);\\n  const v2 = verify(tag); assert(v2.ok, \\\"POST_HEAL_VERIFY_FAILED\\\");\\n\\n  return { ok: true, snapshot_hash: s.snapshot_hash, restored_events: healed.restored_events, head_hash: healed.head_hash };\\n}\\n\\nfunction stress(tag, rounds = 15) {\\n  tag = normTag(tag);\\n  for (let i = 1; i \u003c= rounds; i++) {\\n    try { chaos(tag); }\\n    catch (e) { fail(ERR.STRESS_FAILED, { round: i, code: e.code || e.message, extra: e.extra || null }); }\\n  }\\n  return { ok: true, rounds };\\n}\\n\\n// ---------------- CLI ----------------\\nconst has = (f) =\u003e process.argv.includes(f);\\nconst arg = (f, d = null) =\u003e { const i = process.argv.indexOf(f); return i === -1 ? d : (process.argv[i + 1] ?? d); };\\n\\nif (require.main === module) {\\n  const state = arg(\\\"--state\\\", \\\"IL\\\");\\n\\n  if (has(\\\"--verify\\\")) console.log(JSON.stringify(verify(state), null, 2));\\n  else if (has(\\\"--snapshot\\\")) console.log(JSON.stringify(snapshot(state), null, 2));\\n  else if (has(\\\"--restore\\\")) console.log(JSON.stringify(shadowHeal(state), null, 2));\\n  else if (has(\\\"--condense\\\")) console.log(JSON.stringify(condenseDistrictState(state), null, 2));\\n  else if (has(\\\"--restore-snap\\\")) console.log(JSON.stringify(restoreDistrictStateByHash(arg(\\\"--restore-snap\\\")), null, 2));\\n  else if (has(\\\"--chaos\\\")) console.log(JSON.stringify(chaos(state), null, 2));\\n  else if (has(\\\"--stress\\\")) console.log(JSON.stringify(stress(state, parseInt(arg(\\\"--stress\\\", \\\"15\\\"), 10)), null, 2));\\n  else console.log(JSON.stringify({ verify: verify(state) }, null, 2));\\n}\\n\\nmodule.exports = {\\n  stitchBrick,\\n  appendEvent: stitchBrick,\\n  verify,\\n  snapshot,\\n  latestSnap,\\n  shadowHeal,\\n  condenseDistrictState,\\n  restoreDistrictStateByHash,\\n  chaos,\\n  stress,\\n  canonicalize: canon,\\n};\\n```\",\"status\",\"finished_successfully\",\"end_turn\",\"weight\",1,{\"_69\":70,\"_71\":72,\"_73\":74,\"_75\":76,\"_77\":78,\"_79\":80,\"_81\":82,\"_83\":84,\"_85\":86,\"_87\":12,\"_88\":89,\"_90\":91,\"_92\":93},\"citations\",[],\"content_references\",[],\"resolved_model_slug\",\"gpt-5-2-auto-thinking\",\"gizmo_id\",\"g-p-699edd084b188191a7367d3b157262dc\",\"search_result_groups\",[],\"model_slug\",\"gpt-5-2-thinking\",\"request_id\",\"4ad02086-2bd7-40f6-aeb9-f60778fd68fa\",\"message_type\",\"next\",\"default_model_slug\",\"gpt-5-3\",\"can_save\",\"parent_id\",\"71124e1f-9c63-473b-82fb-b0a19b7ff16a\",\"turn_exchange_id\",\"66189076-5cba-47db-813e-c8a192efb860\",\"token_count\",4286,\"recipient\",\"all\",\"channel\",\"final\",\"group_chat_id\",\"preview_image_url\",\"https://ogimg.chatgpt.com/?postId=t_69a81f089b848191ae0940c06f2badf7\",\"permalink\",\"https://chatgpt.com/s/t_69a81f089b848191ae0940c06f2badf7\",\"permissions\",{\"_105\":12,\"_106\":12,\"_107\":12,\"_108\":12,\"_109\":110},\"can_read\",\"can_write\",\"can_delete\",\"can_